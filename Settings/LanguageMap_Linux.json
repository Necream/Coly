{
    "C++": {
        "needcompile": true,
        "extension": "cpp",
        "compilerun": "g++ -std=c++20 -o ^ $ -I/usr/local/include/coly -I/usr/local/include/coly/LanguageSyncLib && ^.exe *",
        "compile": "cl /nologo /std:c++20 /utf-8 /EHsc $ /Fe:^.exe > nul",
        "run": "^.exe *"
    },
    "Python": {
        "needcompile": false,
        "extension": "py",
        "run": "py $ *"
    },
    "Coly": {
        "needcompile": false,
        "extension": "cly",
        "run": "/usr/local/bin/coly $ *"
    }
}
